// finding occurence of element in sorted array


class Main {
    public static void main(String[] args) {
      int[] arr = {10, 20, 20, 30, 30, 30};
      
      int count=0;
      
      for(int i=0; i<arr.length; i++)
      {
          count++;
          if(i==arr.length-1 || arr[i]!=arr[i+1])
        {  System.out.println(arr[i]+": "+count);
          count=0;}
          
          
      }
    }
}
